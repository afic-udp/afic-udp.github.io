---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Ayudantías FIC" bodyId="index">
  <main class="slide-container">
    <nav class="home-nav" aria-label="Navegación principal">
      <a href="quienes-somos/">Quiénes somos</a>
      <a href="apoyanos/">Apóyanos</a>
      <a href="contacto/">Contacto</a>
    </nav>
    <div class="mobile-mark" aria-hidden="true">
      <span class="mobile-mark-half mobile-mark-top">AFIC</span>
      <span class="mobile-mark-half mobile-mark-bottom">AFIC</span>
    </div>
    <section class="top-half">
      <h1 class="title-top">AYUDANTÍAS</h1>
    </section>
    <section class="bottom-half">
      <h1 class="title-bottom">FIC</h1>
      <a href="materiales/" class="subtitle">VER MATERIALES</a>
      <p class="made-by">
        Hecho por <a href="https://github.com/lavapatos" target="_blank" rel="noopener noreferrer">@lavapatos</a> para AFIC
      </p>
    </section>
  </main>
</BaseLayout>
