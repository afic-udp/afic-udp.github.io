---
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contacto — Ayudantías FIC" bodyId="info">
  <SiteHeader current="contacto" />
  <main class="info-shell">
    <section class="info-panel">
      <h1>Ponte en contacto</h1>
      <p>Si tienes dudas, quieres avisar un error o coordinar material para subir, escríbenos por estos canales.</p>
      <div class="contact-list">
        <a class="contact-link" href="mailto:ayudantias.fic@org.estudiantilesudp.cl">
          <span class="contact-icon" aria-hidden="true">
            <img src="https://cdn.simpleicons.org/gmail/ff0000" alt="" loading="lazy" />
          </span>
          <span>ayudantias.fic@org.estudiantilesudp.cl</span>
        </a>
        <a class="contact-link" href="https://www.instagram.com/ayudantias.fic/" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon" aria-hidden="true">
            <img src="https://cdn.simpleicons.org/instagram/ff0000" alt="" loading="lazy" />
          </span>
          <span>Instagram</span>
        </a>
        <a class="contact-link" href="https://discord.gg/KdKAnTCzd" target="_blank" rel="noopener noreferrer">
          <span class="contact-icon" aria-hidden="true">
            <img src="https://cdn.simpleicons.org/discord/ff0000" alt="" loading="lazy" />
          </span>
          <span>Discord</span>
        </a>
      </div>
    </section>
  </main>
</BaseLayout>
